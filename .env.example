# Frontend
# Legacy variable name kept for compatibility.
# This should point at the Kaido backend, which handles search, info, and stream lookup.
VITE_CONSUMET_API_URL=http://127.0.0.1:3000
#VITE_CONSUMET_API_URL=https://kaido-api.onrender.com
#VITE_CONSUMET_API_URL=https://kaido-api-production.up.railway.app

# Optional external HLS proxy, following the Kitsune setup.
# When set, the frontend requests raw stream URLs from the backend and routes playback
# through this proxy instead of /anime/gogoanime/proxy-stream on the API host.
#VITE_PROXY_URL=http://127.0.0.1:4040
#VITE_PROXY_URL=https://your-proxy-domain.example.com

# Backend
# Frontend origins allowed to call the backend API.
# Multiple origins can be provided as a comma-separated list.
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Public backend origin used when rewriting stream playlists and segment URLs.
PUBLIC_URL=http://127.0.0.1:3000
#HOST=127.0.0.1
#PORT=3000

# Production examples
#FRONTEND_ORIGIN=https://kaido.vercel.app
#PUBLIC_URL=https://kaido-api.onrender.com

# The backend still exposes /anime/gogoanime/proxy-stream for local fallback.
# In production, prefer VITE_PROXY_URL if your API host is blocked by stream CDNs.
