# Backend
# Frontend origins allowed to call the backend API.
# Multiple origins can be provided as a comma-separated list.
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Public backend origin used when rewriting proxied HLS URLs.
PUBLIC_URL=http://127.0.0.1:3000
#HOST=127.0.0.1
#PORT=3000

# This API still supports /anime/gogoanime/proxy-stream for local fallback.
# If the deployed API host is blocked by stream CDNs, use a separate proxy service
# from the frontend via VITE_PROXY_URL.
